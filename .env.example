# Ally Vision v2 — copy to .env and fill in values
# NEVER commit .env

# Profile switch
PROFILE=dev

QWEN_REALTIME_MODEL=qwen3.5-omni-plus-realtime

# DashScope (required for everything)
DASHSCOPE_REGION=singapore
DASHSCOPE_API_KEY=your_dashscope_api_key_here

# DashScope endpoints
DASHSCOPE_HTTP_BASE=https://dashscope-intl.aliyuncs.com/api/v1
DASHSCOPE_REALTIME_URL=wss://dashscope-intl.aliyuncs.com/api-ws/v1/realtime
DASHSCOPE_COMPAT_BASE=https://dashscope-intl.aliyuncs.com/compatible-mode/v1

# Realtime models (auto-selected by PROFILE)
QWEN_REALTIME_DEV=qwen3.5-omni-plus-realtime
QWEN_REALTIME_EXAM=qwen3.5-omni-plus-realtime

# Preferred heavy vision override
QWEN_HEAVY_VISION_MODEL=qwen3.6-plus

# Preferred realtime voice override
QWEN_OMNI_VOICE=Tina

# Heavy vision models (auto-selected by PROFILE)
QWEN_VISION_DEV=qwen3.6-plus
QWEN_VISION_EXAM=qwen3.6-plus

# Transcription (informational — fixed by DashScope)
QWEN_TRANSCRIPTION_MODEL=gummy-realtime-v1

# Embedding
EMBEDDING_MODEL=text-embedding-v4
EMBEDDING_DIMENSIONS=1024
EMBEDDING_OUTPUT_TYPE=dense

# App
APP_HOST=127.0.0.1
APP_PORT=8000
DEBUG=true
